# ===========================================
# EXEMPLE DE CONFIGURATION - COPIER VERS .env
# ===========================================

# Environnement: development | production | test
NODE_ENV=development

# Serveur HTTP
PORT=3000

# WebSocket pour le jeu Pong temps réel
WS_PORT=3001

# Base de données SQLite
DATABASE_PATH=./data/transcendence.db

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:5173

# OAuth 42 (à configurer plus tard)
# FORTYTWO_CLIENT_ID=
# FORTYTWO_CLIENT_SECRET=
# FORTYTWO_REDIRECT_URI=
